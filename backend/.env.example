# Generate a strong secret key — run this in your terminal:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-chars-here

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# From Supabase: Settings → Database → Connection string (URI tab)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres

# "development" or "production"
# In development, cookies are set with secure=False (HTTP is fine on localhost)
# In production, cookies are set with secure=True (requires HTTPS)
ENV=development

# Comma-separated list of frontend origins allowed to call this API.
# Development default: just localhost
# Production (set in Render dashboard): your Vercel domain(s)
ALLOWED_ORIGINS=http://localhost:3000
